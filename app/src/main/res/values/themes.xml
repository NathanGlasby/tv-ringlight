<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.RingLight" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorPrimary">#FFD27F</item>
        <item name="android:colorAccent">#FFD27F</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
    </style>

    <!-- Fully transparent, no-animation theme for TrampolineActivity -->
    <style name="Theme.Transparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="SectionLabel" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFD27F</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="StepButton" parent="@android:style/Widget.Button">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="StepValue" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">120dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">22sp</item>
    </style>

</resources>
